# Copy to .env and add your keys:  cp .env.example .env
# Restart the dev server after editing (npm run dev).

VITE_OPENAI_API_KEY=your_openai_key_here

# Cloud sync (Supabase) — optional but required for sync across devices
# Create a project at https://supabase.com, run supabase/schema.sql in SQL Editor
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
